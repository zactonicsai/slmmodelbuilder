# Auto-generated by SLM Data Generator
# Trains a LoRA adapter, merges into base, and converts to GGUF.

FROM pytorch/pytorch:2.4.1-cpu

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    HF_HUB_DISABLE_PROGRESS_BARS=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        git cmake build-essential ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

# llama.cpp — needed for GGUF conversion + quantization
RUN git clone --depth=1 https://github.com/ggerganov/llama.cpp /opt/llama.cpp
RUN cd /opt/llama.cpp && \
    cmake -B build -DGGML_CUDA=OFF -DLLAMA_CURL=OFF && \
    cmake --build build --config Release -j"$(nproc)" --target llama-quantize
RUN pip install -r /opt/llama.cpp/requirements.txt

# Fine-tuning stack
RUN pip install \
        "transformers>=4.45,<5" \
        "peft>=0.13" \
        "datasets>=3.0" \
        "accelerate>=0.34" \
        "trl>=0.11" \
        "sentencepiece" \
        "protobuf" \
        "tensorboard"

WORKDIR /workspace
COPY train.py convert.sh run_all.sh Modelfile ./
RUN chmod +x convert.sh run_all.sh

CMD ["bash", "run_all.sh"]
